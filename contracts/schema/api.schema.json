{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "api.yaml",
  "type": "object",
  "required": ["endpoints"],
  "properties": {
    "endpoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["method", "path", "slice"],
        "additionalProperties": false,
        "properties": {
          "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
          "path": { "type": "string", "pattern": "^/" },
          "slice": { "type": "string", "pattern": "^S[0-9]{2}$" }
        }
      }
    },
    "ignore_paths": {
      "type": "array",
      "items": { "type": "string", "pattern": "^/" }
    }
  },
  "additionalProperties": false
}
