{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "layer-rules.yaml",
  "type": "object",
  "required": ["backend", "frontend"],
  "properties": {
    "backend": { "$ref": "#/$defs/layerSide" },
    "frontend": { "$ref": "#/$defs/layerSide" }
  },
  "$defs": {
    "layerSide": {
      "type": "object",
      "properties": {
        "base_package": { "type": "string" },
        "root": { "type": "string" },
        "forbidden_imports": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "not_import"],
            "properties": {
              "from": { "type": "string" },
              "not_import": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        },
        "rules": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
