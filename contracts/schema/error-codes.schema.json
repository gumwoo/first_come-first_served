{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "error-codes.yaml",
  "type": "object",
  "required": ["codes"],
  "additionalProperties": false,
  "properties": {
    "codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["code", "http"],
        "additionalProperties": false,
        "properties": {
          "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
          "http": { "type": "integer", "minimum": 100, "maximum": 599 }
        }
      }
    }
  }
}
