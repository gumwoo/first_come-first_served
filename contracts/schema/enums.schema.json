{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "enums.yaml",
  "type": "object",
  "minProperties": 1,
  "additionalProperties": {
    "type": "object",
    "required": ["values"],
    "additionalProperties": false,
    "properties": {
      "values": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string" },
        "uniqueItems": true
      },
      "transitions": {
        "type": "object",
        "additionalProperties": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
